{
  "11129986678929914452": {
    "build": {
      "command": "next build",
      "options": {
        "cwd": "apps/web",
        "tty": false
      },
      "dependsOn": [
        "^build"
      ],
      "cache": true,
      "inputs": [
        "default",
        "^default",
        {
          "externalDependencies": [
            "next"
          ]
        }
      ],
      "outputs": [
        "{workspaceRoot}/apps/web/.next",
        "{workspaceRoot}/apps/web/.next/!(cache)"
      ]
    },
    "serve": {
      "command": "next dev",
      "options": {
        "cwd": "apps/web"
      }
    },
    "start": {
      "command": "next start",
      "options": {
        "cwd": "apps/web"
      },
      "dependsOn": [
        "build"
      ]
    },
    "serve-static": {
      "command": "next start",
      "options": {
        "cwd": "apps/web"
      },
      "dependsOn": [
        "build"
      ]
    },
    "build-deps": {
      "dependsOn": [
        "^build"
      ]
    },
    "watch-deps": {
      "dependsOn": [
        "build-deps"
      ],
      "command": "pnpm exec nx watch --projects web --includeDependentProjects -- pnpm exec nx build-deps web"
    }
  },
